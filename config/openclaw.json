{
  // Mighty Craw — Gateway Configuration
  // Docs: https://docs.openclaw.ai/gateway/configuration

  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
  },

  agents: {
    defaults: {
      model: {
        primary: "openrouter/anthropic/claude-sonnet-4-6",
      },
    },
    list: [
      {
        id: "main",
        identity: {
          name: "Mighty Craw",
          emoji: "🦞",
          theme: "helpful, sharp, loyal community assistant",
        },
      },
    ],
  },

  channels: {
    discord: {
      enabled: true,
      token: {
        source: "env",
        provider: "default",
        id: "DISCORD_BOT_TOKEN",
      },

      // Privileged gateway intents (enable in Discord Dev Portal too)
      intents: {
        guildMembers: true,
      },

      // Default: respond only when @mentioned in servers
      groupPolicy: "allowlist",
      dmPolicy: "pairing",

      guilds: {
        // Replace YOUR_SERVER_ID with your Discord server's ID
        // YOUR_SERVER_ID: {
        //   requireMention: false,
        //   welcomeChannelId: "YOUR_WELCOME_CHANNEL_ID",
        // },
      },

      streaming: {
        mode: "progress",
      },

      actions: {
        messages: true,
        reactions: true,
        threads: true,
        memberInfo: true,
      },
    },
  },
}
